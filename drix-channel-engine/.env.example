# ---- Required ----
# OpenRouter (never hardcode the model id; it comes from here)
OPENROUTER_API_KEY=sk-or-your-key
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4.5

# Postgres. Locally point at your local pg. On Railway this is injected automatically.
DATABASE_URL=postgresql://user:pass@localhost:5432/drix_channel

# ---- Optional ----
# Set to true when your Postgres requires SSL (most managed/external connections).
# Railway internal connections usually do NOT need this. Default off.
DATABASE_SSL=false

# Port. Railway injects PORT automatically; locally defaults to 3000.
PORT=3000
